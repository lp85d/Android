modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["gradle"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Smart Android Monitor"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Proactive Monitor"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Проактивный мониторинг GitHub Actions"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "APK Monitor"

[[workflows.workflow]]
name = "Smart Android Monitor"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python github_actions_monitor.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Proactive Monitor"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python proactive_monitor.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Проактивный мониторинг GitHub Actions"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python proactive_monitor.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "APK Monitor"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python github_actions_monitor.py --interval=20"

[workflows.workflow.metadata]
outputType = "console"
